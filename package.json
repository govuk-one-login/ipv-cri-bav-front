{
  "name": "ipv-cri-bav-front",
  "version": "0.0.1",
  "description": "Frontend for the identify proving and bank account verification CRI",
  "main": "index.js",
  "engines": {
    "node": "22.*",
    "yarn": "1.22.*"
  },
  "scripts": {
    "start": "node src/app.js",
    "start:ci": "REDIS_SESSION_URL= NODE_ENV=development node src/app.js",
    "start:debug": "DEBUG=* node src/app.js",
    "build": "yarn build-sass && yarn build-js && yarn copy-assets",
    "dev": "nodemon src/app.js",
    "build-sass": "rm -rf dist/public/stylesheets/application.css && sass --no-source-map src/assets/scss/application.scss dist/public/stylesheets/application.css --style compressed",
    "build-js": "yarn build-js:analytics && yarn build-js:all && yarn build-js:device-intelligence",
    "build-js:analytics": "mkdir -p dist/public/javascripts; uglifyjs node_modules/@govuk-one-login/di-ipv-cri-common-express/src/assets/javascript/analytics/ua/init.js node_modules/@govuk-one-login/frontend-analytics/lib/analytics.js -o dist/public/javascripts/analytics.js",
    "build-js:device-intelligence": "mkdir -p dist/public/javascripts; uglifyjs node_modules/@govuk-one-login/frontend-device-intelligence/build/esm/index.js -o dist/public/javascripts/deviceIntelligence.js",
    "build-js:all": "mkdir -p dist/public/javascripts; uglifyjs node_modules/govuk-frontend/govuk/all.js node_modules/hmpo-components/all.js --beautify -o dist/public/javascripts/all.js",
    "copy-assets": "mkdir -p dist/public/images && cp -R src/assets/images/* dist/public/images",
    "lint": "eslint .",
    "prettier": "prettier \"**/*.{js,md}\" --check",
    "prettier:fix": "yarn prettier --write",
    "format": "yarn prettier:fix && yarn lint",
    "test": "node_modules/.bin/jest --testPathPatterns=app/bav --coverage",
    "test:browser:report": "node ./test/utils/multiReportGenerator.js",
    "test:browser": "wait-on tcp:127.0.0.1:5040 && cucumber-js test/browser/features/**/*.feature --require test/browser/support/setup.js --require test/browser/step_definitions/**/*.js -f json:./test/reports/cucumber_report.json --tags @success",
    "test:browser:ci": "npm run start:ci & npm run test:browser && kill $! && npm run test:browser:report",
    "test:e2e:cd:cucumber": "cucumber-js test/browser/features/**/*.feature --require test/browser/support/setup.js --require test/browser/step_definitions/**/*.js -f json:./test/reports/cucumber_report.json --tags \"@e2e or @success\"",
    "test:e2e:cd": "npm run test:e2e:cd:cucumber && npm run test:browser:report",
    "test:pii": "bash ./check-logs.sh",
    "check-translation": "node node_modules/@govuk-one-login/di-ipv-cri-common-express/scripts/checkTranslations.js '../../../../src/locales'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/govuk-one-login/ipv-cri-bav-front"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/govuk-one-login/ipv-cri-bav-front/issues"
  },
  "homepage": "https://github.com/govuk-one-login/ipv-cri-bav-front#readme",
  "packageManager": "yarn@1.22.22",
  "devDependencies": {
    "@aws-sdk/credential-providers": "3.984.0",
    "@aws-sdk/util-dynamodb": "3.984.0",
    "@cucumber/cucumber": "12.6.0",
    "@jest/globals": "30.2.0",
    "@playwright/test": "1.58.2",
    "axe-core": "4.10.3",
    "axe-playwright": "2.1.0",
    "eslint": "10.0.1",
    "eslint-config-prettier": "10.1.8",
    "jest": "30.2.0",
    "jest-cucumber": "4.5.0",
    "multiple-cucumber-html-reporter": "3.9.3",
    "nodemon": "3.1.14",
    "nyc": "18.0.0",
    "playwright": "1.58.2",
    "prettier": "3.2.5",
    "sass": "1.71.1",
    "uglify-js": "3.17.4",
    "wait-on": "9.0.3",
    "globals": "17.3.0",
    "@eslint/js": "10.0.1",
    "@eslint/eslintrc": "3.3.4"
  },
  "dependencies": {
    "@govuk-one-login/di-ipv-cri-common-express": "12.0.2",
    "@govuk-one-login/frontend-analytics": "4.0.7",
    "@govuk-one-login/frontend-device-intelligence": "1.2.0",
    "@govuk-one-login/frontend-language-toggle": "1.1.0",
    "@govuk-one-login/frontend-passthrough-headers": "1.3.2",
    "@govuk-one-login/frontend-ui": "4.2.2",
    "@govuk-one-login/frontend-vital-signs": "0.1.3",
    "@aws-sdk/client-dynamodb": "3.984.0",
    "ajv": "8.18.0",
    "ajv-formats": "2.1.1",
    "aws4-axios": "3.4.0",
    "axios": "1.13.5",
    "connect-dynamodb": "3.0.5",
    "dotenv": "16.3.1",
    "express": "4.22.1",
    "express-async-errors": "3.1.1",
    "express-session": "1.18.2",
    "govuk-frontend": "4.10.1",
    "hmpo-app": "3.0.1",
    "hmpo-components": "7.1.1",
    "hmpo-config": "4.0.0",
    "hmpo-form-wizard": "13.0.2",
    "hmpo-i18n": "7.0.1",
    "hmpo-logger": "8.0.3",
    "node-rsa": "1.1.1",
    "nunjucks": "3.2.4"
  },
  "resolutions": {
    "string-width": "4.2.3",
    "form-data": "4.0.4"
  }
}
